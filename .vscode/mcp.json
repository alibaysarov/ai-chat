{
	"servers": {
		"Prisma-Local": {
			"command": "npx",
			"args": [
				"-y",
				"prisma",
				"mcp"
			],
			"type": "stdio"
		},
		"Prisma-Remote": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-remote",
				"https://mcp.prisma.io/mcp"
			],
			"type": "stdio"
		},
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest",
				"--browser",
				"chrome"
			],
			"type": "stdio"
		},
		"zapier": {
			"url": "https://mcp.zapier.com/api/v1/connect",
			"type": "http",
			"icons": {
				"src": "https://mcp.zapier.com/icon-mcp.png"
			}
		}
	},
	"inputs": []
}