# Database (used by docker-compose.local.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_chat
DATABASE_URL=postgresql://postgres:postgres@database:5432/ai_chat

# Auth — must be at least 32 characters
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# OpenAI
OPENAI_API_KEY=sk-...

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# n8n MCP integration (Google Drive / Sheets tools) — optional
N8N_MCP_URL=http://n8n:5678/mcp-webhook/<your-trigger-path>
N8N_MCP_API_KEY=your-n8n-mcp-api-key

# Zapier MCP integration (Google Sheets tools) — optional
ZAPIER_MCP_URL=https://mcp.zapier.com/api/v1/connect
ZAPIER_MCP_API_KEY=

# Client (Vite — prefix with VITE_)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
